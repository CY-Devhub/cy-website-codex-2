<script is:inline>
  (() => {
    const stacks = document.querySelectorAll("[data-module-stack]");
    stacks.forEach((stack) => {
      const rows = Array.from(stack.querySelectorAll("[data-module-row]"));
      if (rows.length === 0) return;
      let autoIndex = 0;
      let autoLockedUntil = 0;
      let cycleTimer;

      const clearActive = () => {
        rows.forEach((row) => {
          row.classList.remove("is-active");
          row.classList.remove("is-auto");
          const toggle = row.querySelector("[data-module-toggle]");
          if (toggle) toggle.setAttribute("aria-pressed", "false");
        });
      };

      const queueCycle = (delay = 900) => {
        window.clearTimeout(cycleTimer);
        cycleTimer = window.setTimeout(runCycle, delay);
      };

      const runCycle = () => {
        if (Date.now() < autoLockedUntil || document.hidden) {
          queueCycle(1200);
          return;
        }
        if (rows.some((row) => row.classList.contains("is-active"))) {
          queueCycle(1200);
          return;
        }

        const row = rows[autoIndex % rows.length];
        row.classList.add("is-auto");

        window.setTimeout(() => {
          row.classList.remove("is-auto");
          autoIndex = (autoIndex + 1) % rows.length;
          queueCycle(600);
        }, 4000);
      };

      rows.forEach((row) => {
        const toggle = row.querySelector("[data-module-toggle]");
        if (!toggle) return;

        toggle.addEventListener("click", () => {
          const wasActive = row.classList.contains("is-active");
          clearActive();
          autoLockedUntil = Date.now() + 10000;
          if (!wasActive) {
            row.classList.add("is-active");
            toggle.setAttribute("aria-pressed", "true");
          }
          queueCycle(10500);
        });
      });

      document.addEventListener("pointerdown", (event) => {
        if (!(event.target instanceof Node)) return;
        if (!stack.contains(event.target)) {
          clearActive();
          autoLockedUntil = Date.now();
          queueCycle(1000);
        }
      });

      queueCycle(1300);
    });
  })();
</script>

