---
import heroImage from "../assets/img/CUREO5/CUREO5_Grouptherapy_clinics.jpg";
import groupClinicImage from "../assets/img/CUREO5/CUREO5_HappyGroupTherapy.webp";
import groupUiImage from "../assets/img/CUREO5/CUREO5_GroupTherapyScreenShot.jpeg";
import navigatorImage from "../assets/img/CUREO5/CUREO5_NavigatorScreenshot.jpeg";
import bedsideImage from "../assets/img/CUREO5/CUREO_Bedsite_Therapy.jpg";
import reportImage from "../assets/img/CUREO5/CUREO5_Therapy_Report_Mock.jpeg";
import growthImage from "../assets/img/CUREO5/CUREO5_HappyPatientTherapist.jpg";
import hubImage from "../assets/img/CUREO5/CUREO5_Hub_Mock.png";

const logoModules = import.meta.glob("../assets/img/logos/partner/*.{png,jpg,jpeg,webp,svg}", {
  eager: true,
  import: "default"
});

const toAssetUrl = (asset) => {
  if (typeof asset === "string") return asset;
  if (asset && typeof asset === "object" && "src" in asset) return asset.src;
  return "";
};

const logos = Object.entries(logoModules)
  .map(([path, asset]) => {
    const file = path.split("/").pop() ?? "";
    const label = file
      .replace(/\.[^/.]+$/, "")
      .replace(/[_-]+/g, " ")
      .replace(/\s+Ambulant$/i, "")
      .trim();
    return { file, src: toAssetUrl(asset), alt: `${label} logo` };
  })
  .filter((logo) => !/ambulant/i.test(logo.file))
  .sort((a, b) => a.file.localeCompare(b.file));

const lang = Astro.props.lang === "de" ? "de" : "en";
const base = import.meta.env.BASE_URL || "/";
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const secondaryHref = lang === "de"
  ? `${normalizedBase}de/our-therapy-solution`
  : `${normalizedBase}our-therapy-solution`;

const copy = lang === "de"
  ? {
      heroTitle: "CUREO VR-Therapie für Reha- und Akutkliniken",
      heroSubtitle: "Entwickelt, um in stationären Versorgungsstrukturen echte Entlastung und messbare Therapieergebnisse zu liefern.",
      heroPrimaryCta: "Termin buchen",
      heroSecondaryCta: "Therapielösung ansehen",

      selectorTitle: "Wählen Sie Ihren Klinikfokus",
      selectorText:
        "CUREO adressiert stationäre Rehabilitation und Akutversorgung mit jeweils passenden Workflows. Wählen Sie den Bereich und springen Sie direkt zum relevanten Abschnitt.",
      selectorRehabTitle: "Rehabilitationskliniken",
      selectorRehabBody: "Fokus auf Einzel-/Gruppentherapie und Therapie-Navigator",
      selectorRehabImage:
        "https://cdn.prod.website-files.com/6548c6e5ab9a929dbb64e897/69032049a209d4dfd000f27d_DSC02952.jpg",
      selectorAcuteTitle: "Akutkliniken",
      selectorAcuteBody: "Fokus auf Bettseitentherapie und Frühphase-Rehabilitation",
      selectorAcuteImage:
        "https://cdn.prod.website-files.com/6548c6e5ab9a929dbb64e897/68de6d9e0bc26e4b64672f16_PatientenBettJPG.jpg",

      rehabTitle: "Für Rehabilitationskliniken",
      rehabIntro:
        "In stationären Rehabilitationskliniken ermöglicht CUREO individualisierte Gruppentherapie mit klaren Prozessen und hoher Behandlungskapazität.",
      rehabGroupTitle: "Individualisierte Gruppentherapie",
      rehabGroupBody:
        "Mit CUREO GROUP können bis zu sechs Patienten gleichzeitig behandelt werden, während jeder Patient in einer eigenen virtuellen Umgebung mit individuellen Instruktionen trainiert.",
      rehabGroupBenefits: [
        "Bis zu 6 Patienten parallel behandeln und Therapiezeit effizienter nutzen.",
        "Einheitliche, indikationsbasierte Trainingspläne für die Gruppe zuweisen oder individuelle Pläne für einzelne Patienten erstellen.",
        "Therapeuten bleiben jederzeit flexibel zwischen Gruppen- und Einzelmodus.",
        "Mehr Zeit für Patientenversorgung, weniger Aufwand für Organisation und Dokumentation."
      ],
      rehabNavigatorTitle: "Therapie-Navigator und Trainingsplan",
      rehabNavigatorBody:
        "Der Therapie-Navigator unterstützt Ihr Team bei Planung, Zuweisung und Steuerung laufender Sitzungen und schafft einen konsistenten Ablauf über alle Therapieräume hinweg.",
      rehabNavigatorBenefits: [
        "Der Therapie-Navigator unterstützt Planung, Patientenzuweisung, Sitzungssteuerung und Abschlussdokumentation.",
        "Die Benutzeroberfläche zeigt aktive Sessions, Verbindungsstatus und verfügbare Headsets auf einen Blick.",
        "Für Patienten ist klar erkennbar, welches Training aktiv ist; neue Sessions können zum richtigen Zeitpunkt gestartet werden."
      ],

      acuteTitle: "Für Akutkliniken",
      acuteIntro:
        "Für die Akutversorgung liefert CUREO niedrigschwellige, motivierende Therapieeinheiten am Bett und in der Frühphase, abgestimmt auf neurologische und funktionelle Einschränkungen.",
      acuteBedsideText:
        "Bettseitentherapie ermöglicht frühe Aktivierung direkt in der klinischen Umgebung und reduziert organisatorischen Aufwand.",
      acuteEarlyText:
        "Frühphase-Rehabilitation mit klaren, geführten Übungen unterstützt den schnellen Therapiebeginn und eine sichere Progression.",

      sharedTitle: "Für beide Kliniktypen: ein gemeinsamer Qualitätsstandard",
      sharedIntro:
        "CUREO hilft Ihrem Team mit einem modernen Behandlungsstandard, verbessert Sicherheit in der Anwendung und erleichtert Einarbeitung, Skalierung und Planung.",
      sharedCardA: "Automatisch erstellte Fortschrittsberichte und Administrationsdaten unterstützen schnellere und bessere klinische Entscheidungen.",
      sharedCardB: "Navigator und Therapieplanung bilden einen strukturierten Prozess von Vorbereitung bis Abschlussdokumentation ab.",
      sharedCardC: "Der CUREO Hub macht Verläufe transparent, standardisiert Workflows und verbessert die teamübergreifende Abstimmung.",

      trustTitle: "Führende medizinische Einrichtungen vertrauen auf CUREO",
      expertTitle: "Rückmeldung aus der Praxis",
      expertQuote:
        "Durch die klare Struktur und die hohe Patientenmotivation können wir Therapiezeit deutlich effizienter nutzen.",
      expertName: "Prof. Dr. med. Max Muster",
      finalTitle: "Gestalten Sie die Zukunft der Therapie mit CUREO",
      finalCta: "Termin vereinbaren"
    }
  : {
      heroTitle: "CUREO VR Therapy for Rehabilitation and Acute Clinics",
      heroSubtitle: "Designed to deliver measurable outcomes and operational relief in inpatient care environments.",
      heroPrimaryCta: "Book appointment",
      heroSecondaryCta: "View therapy solution",

      selectorTitle: "Choose your clinic focus",
      selectorText:
        "CUREO supports both inpatient rehabilitation and acute-care workflows. Select a path to jump straight to the most relevant section.",
      selectorRehabTitle: "Rehabilitation Clinics",
      selectorRehabBody: "Focus on individual/group therapy and therapy navigator",
      selectorRehabImage:
        "https://cdn.prod.website-files.com/6548c6e5ab9a929dbb64e897/69032049a209d4dfd000f27d_DSC02952.jpg",
      selectorAcuteTitle: "Acute Clinics",
      selectorAcuteBody: "Focus on bedside therapy and early-phase rehabilitation",
      selectorAcuteImage:
        "https://cdn.prod.website-files.com/6548c6e5ab9a929dbb64e897/68de6d9e0bc26e4b64672f16_PatientenBettJPG.jpg",

      rehabTitle: "For rehabilitation clinics",
      rehabIntro:
        "In inpatient rehabilitation clinics, CUREO enables individualized group therapy with clear workflows and high treatment capacity.",
      rehabGroupTitle: "Individualized Group Therapy",
      rehabGroupBody:
        "With CUREO GROUP, up to six patients can be treated simultaneously while each patient trains in their own virtual environment with dedicated instructions.",
      rehabGroupBenefits: [
        "Treat up to 6 patients in parallel and use therapy time more efficiently.",
        "Assign one indication-based group plan or create individualized plans for specific patients.",
        "Therapists can stay flexible between group mode and one-on-one treatment at any time.",
        "More time for patient care with less operational and documentation overhead."
      ],
      rehabNavigatorTitle: "Therapy Navigator and Training Plan",
      rehabNavigatorBody:
        "Therapy Navigator helps your team plan, assign, and control ongoing sessions, creating one consistent workflow across treatment rooms.",
      rehabNavigatorBenefits: [
        "Therapy Navigator supports planning, patient assignment, session control, and final documentation.",
        "The interface gives a fast overview of active sessions, connection status, and available headsets.",
        "Patients can clearly see which training is active, while therapists launch new sessions at the right moment."
      ],

      acuteTitle: "For acute clinics",
      acuteIntro:
        "For acute settings, CUREO provides low-threshold, motivating therapy sessions at bedside and in early rehabilitation phases, adapted to neurological and functional limitations.",
      acuteBedsideText:
        "Bedside therapy supports early activation directly in the ward environment and reduces logistical overhead.",
      acuteEarlyText:
        "Early-phase rehabilitation with guided exercises enables faster therapy start and safe, trackable progression.",

      sharedTitle: "For both clinic types: one modern treatment standard",
      sharedIntro:
        "CUREO helps your team work with a modern treatment standard, improving staff confidence, onboarding, and planning reliability.",
      sharedCardA:
        "Automatically generated progress reports and administration data support faster and better clinical decisions.",
      sharedCardB:
        "Navigator and planning tools support a structured process from setup to final documentation.",
      sharedCardC:
        "The CUREO Hub increases transparency, standardizes workflows, and improves alignment across teams.",

      trustTitle: "Leading medical institutions trust CUREO",
      expertTitle: "Clinical expert feedback",
      expertQuote:
        "With clear workflows and high patient engagement, we can use therapy time much more effectively.",
      expertName: "Prof. Dr. med. Max Sample",
      finalTitle: "Join the future of therapy with CUREO",
      finalCta: "Book appointment"
    };
---

<section class="inpatient-page" data-reveal>
  <div class="shell">
    <section class="hero">
      <div class="hero-media">
        <img src={heroImage.src} alt={copy.heroSubtitle} loading="eager" />
        <div class="hero-overlay"></div>
        <div class="hero-copy">
          <h1>{copy.heroTitle}</h1>
          <p>{copy.heroSubtitle}</p>

          <div class="hero-actions">
            <a
              class="hero-btn hero-btn-primary"
              href="https://meetings-eu1.hubspot.com/cureosity/terminbuchungstool-de"
              target="_blank"
              rel="noopener noreferrer"
            >
              {copy.heroPrimaryCta}
            </a>
            <a class="hero-btn hero-btn-secondary" href={secondaryHref}>
              {copy.heroSecondaryCta}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-card clinic-selector">
      <h2>{copy.selectorTitle}</h2>
      <p class="selector-text">{copy.selectorText}</p>
      <div class="selector-grid">
        <a class="selector-link" href="#rehab-clinics">
          <div class="selector-thumb">
            <img src={copy.selectorRehabImage} alt={copy.selectorRehabTitle} loading="lazy" />
            <div class="selector-thumb-overlay"></div>
          </div>
          <strong>{copy.selectorRehabTitle}</strong>
          <span>{copy.selectorRehabBody}</span>
        </a>
        <a class="selector-link" href="#acute-clinics">
          <div class="selector-thumb">
            <img src={copy.selectorAcuteImage} alt={copy.selectorAcuteTitle} loading="lazy" />
            <div class="selector-thumb-overlay"></div>
          </div>
          <strong>{copy.selectorAcuteTitle}</strong>
          <span>{copy.selectorAcuteBody}</span>
        </a>
      </div>
    </section>

    <section id="rehab-clinics" class="section-card anchor-target">
      <h2>{copy.rehabTitle}</h2>
      <p class="section-intro">{copy.rehabIntro}</p>

      <div class="rehab-stack">
        <article class="rehab-adv-row">
          <div class="rehab-media">
            <img src={groupClinicImage.src} alt={copy.rehabGroupTitle} loading="lazy" />
          </div>
          <div class="rehab-content">
            <h3>{copy.rehabGroupTitle}</h3>
            <p class="section-intro rehab-body">{copy.rehabGroupBody}</p>
            <ul class="rehab-benefits">
              {copy.rehabGroupBenefits.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>

        <article class="rehab-adv-row reverse">
          <div class="rehab-media">
            <img src={groupUiImage.src} alt={copy.rehabNavigatorTitle} loading="lazy" />
          </div>
          <div class="rehab-content">
            <h3>{copy.rehabNavigatorTitle}</h3>
            <p class="section-intro rehab-body">{copy.rehabNavigatorBody}</p>
            <ul class="rehab-benefits">
              {copy.rehabNavigatorBenefits.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </section>

    <section id="acute-clinics" class="section-card anchor-target">
      <h2>{copy.acuteTitle}</h2>
      <p class="section-intro">{copy.acuteIntro}</p>

      <div class="two-col">
        <article class="media-note">
          <img src={bedsideImage.src} alt={copy.acuteBedsideText} loading="lazy" />
          <p>{copy.acuteBedsideText}</p>
        </article>
        <article class="media-note">
          <img src={growthImage.src} alt={copy.acuteEarlyText} loading="lazy" />
          <p>{copy.acuteEarlyText}</p>
        </article>
      </div>
    </section>

    <section id="shared-clinic-value" class="section-card">
      <h2>{copy.sharedTitle}</h2>
      <p class="section-intro">{copy.sharedIntro}</p>

      <div class="shared-grid">
        <article class="media-note">
          <img src={reportImage.src} alt={copy.sharedCardA} loading="lazy" />
          <p>{copy.sharedCardA}</p>
        </article>
        <article class="media-note">
          <img src={navigatorImage.src} alt={copy.sharedCardB} loading="lazy" />
          <p>{copy.sharedCardB}</p>
        </article>
        <article class="media-note">
          <img src={hubImage.src} alt={copy.sharedCardC} loading="lazy" />
          <p>{copy.sharedCardC}</p>
        </article>
      </div>
    </section>

    <section class="trust">
      <h2>{copy.trustTitle}</h2>
      <div class="logo-row" role="list" aria-label={copy.trustTitle}>
        {
          logos.slice(0, 8).map((logo) => (
            <article class="logo-card" role="listitem">
              <img src={logo.src} alt={logo.alt} loading="lazy" />
            </article>
          ))
        }
      </div>
    </section>

    <section class="expert section-card">
      <h2>{copy.expertTitle}</h2>
      <article class="expert-box">
        <img src={growthImage.src} alt={copy.expertName} loading="lazy" />
        <blockquote>{copy.expertQuote}</blockquote>
        <p>{copy.expertName}</p>
      </article>
    </section>

    <section class="final-cta">
      <h2>{copy.finalTitle}</h2>
      <a
        href="https://meetings-eu1.hubspot.com/cureosity/terminbuchungstool-de"
        target="_blank"
        rel="noopener noreferrer"
      >
        {copy.finalCta}
      </a>
    </section>
  </div>
</section>

<style>
  .inpatient-page {
    background: #fff;
    padding: clamp(1rem, 2vw, 1.8rem) clamp(0.9rem, 2.4vw, 1.6rem) clamp(2rem, 4vw, 3.2rem);
  }

  .shell {
    margin: 0 auto;
    max-width: 1240px;
    display: grid;
    gap: 1.1rem;
  }

  .hero {
    margin-bottom: 0.3rem;
  }

  .hero-media {
    border: 1px solid #d9e5d2;
    border-radius: 8px;
    min-height: 420px;
    overflow: hidden;
    position: relative;
  }

  .hero img {
    display: block;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    width: 100%;
  }

  .hero-overlay {
    background:
      linear-gradient(105deg, rgba(20, 42, 24, 0.74) 0%, rgba(20, 42, 24, 0.24) 62%, rgba(20, 42, 24, 0.14) 100%),
      linear-gradient(180deg, rgba(111, 156, 33, 0.08), transparent 42%);
    inset: 0;
    position: absolute;
  }

  .hero-copy {
    bottom: clamp(1.3rem, 4.2vw, 2.4rem);
    color: #fff;
    left: clamp(1.1rem, 3.8vw, 2.6rem);
    max-width: min(700px, 90%);
    position: absolute;
    z-index: 1;
  }

  .hero h1 {
    color: #fff;
    font-size: clamp(1.95rem, 4vw, 3.2rem);
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin: 0;
  }

  .hero p {
    color: rgba(242, 252, 236, 0.95);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.45;
    margin: 0.45rem 0 0;
    max-width: 58ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.58rem;
    margin-top: 0.95rem;
  }

  .hero-btn {
    border-radius: 8px;
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.62rem 1rem;
    text-decoration: none;
    transition: transform 160ms ease;
  }

  .hero-btn:hover {
    transform: translateY(-1px);
  }

  .hero-btn-primary {
    background: #6f9c21;
    color: #fff;
  }

  .hero-btn-secondary {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.65);
    color: #fff;
  }

  .section-card {
    background: #fff;
    border: 1px solid #d9e5d2;
    border-radius: 8px;
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .section-card h2,
  .trust h2,
  .final-cta h2 {
    color: #1f3326;
    font-size: clamp(1.35rem, 2.1vw, 2.05rem);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .selector-text,
  .section-intro {
    color: #3f5347;
    line-height: 1.55;
    margin: 0 0 0.9rem;
  }

  .selector-grid {
    display: grid;
    gap: 0.72rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .selector-link {
    background: linear-gradient(180deg, #ffffff 0%, #f6f9f4 100%);
    border: 1px solid #d9e5d2;
    border-radius: 8px;
    color: inherit;
    display: grid;
    gap: 0.5rem;
    padding: 0.7rem;
    text-decoration: none;
    transition: border-color 170ms ease, transform 170ms ease;
  }

  .selector-thumb {
    border-radius: 8px;
    min-height: 140px;
    overflow: hidden;
    position: relative;
  }

  .selector-thumb img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .selector-thumb-overlay {
    background:
      linear-gradient(180deg, rgba(10, 28, 15, 0.1) 0%, rgba(10, 28, 15, 0.58) 100%),
      linear-gradient(115deg, rgba(94, 152, 50, 0.22), rgba(94, 152, 50, 0.04));
    inset: 0;
    position: absolute;
  }

  .selector-link strong {
    color: #1f3326;
    font-size: 1.04rem;
    line-height: 1.2;
  }

  .selector-link span {
    color: #4e6357;
    font-size: 0.94rem;
    line-height: 1.4;
  }

  .selector-link:hover {
    border-color: #9ec46f;
    transform: translateY(-1px);
  }

  .anchor-target {
    scroll-margin-top: 98px;
  }

  .rehab-stack {
    display: grid;
    gap: 0.82rem;
  }

  .rehab-adv-row {
    display: grid;
    gap: clamp(0.75rem, 1.4vw, 1.1rem);
    grid-template-columns: minmax(320px, 1.05fr) minmax(340px, 1fr);
  }

  .rehab-adv-row.reverse .rehab-media {
    order: 2;
  }

  .rehab-adv-row.reverse .rehab-content {
    order: 1;
  }

  .rehab-media img {
    border-radius: 8px;
    display: block;
    height: 100%;
    min-height: 340px;
    object-fit: cover;
    width: 100%;
  }

  .rehab-content {
    align-self: center;
  }

  .rehab-content h3 {
    color: #223628;
    font-size: clamp(1.1rem, 1.5vw, 1.4rem);
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .rehab-body {
    margin-bottom: 0.7rem;
  }

  .rehab-benefits {
    color: #3f5347;
    display: grid;
    gap: 0.36rem;
    margin: 0;
    padding-left: 1.05rem;
  }

  .rehab-benefits li {
    line-height: 1.48;
  }

  .two-col {
    display: grid;
    gap: clamp(0.75rem, 1.4vw, 1.1rem);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .intro-grid {
    margin-bottom: 0.95rem;
  }

  .wide-note {
    align-items: center;
    background: #f8fbf6;
    border-radius: 8px;
    display: grid;
    gap: 0.7rem;
    grid-template-columns: minmax(180px, 280px) 1fr;
    padding: 0.72rem;
  }

  .wide-note img {
    border-radius: 8px;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .wide-note p {
    color: #3f5347;
    line-height: 1.5;
    margin: 0;
  }

  .shared-grid {
    display: grid;
    gap: 0.72rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .media-note {
    background: #f8fbf6;
    border-radius: 8px;
    display: grid;
    gap: 0.45rem;
    min-height: 100%;
    padding: 0.62rem;
  }

  .media-note img {
    border-radius: 8px;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .media-note p {
    color: #3f5347;
    font-size: clamp(0.92rem, 1vw, 0.99rem);
    line-height: 1.48;
    margin: 0;
  }

  .trust {
    display: grid;
    gap: 0.7rem;
  }

  .logo-row {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .logo-card {
    align-items: center;
    background: #fff;
    border: 1px solid #d9e5d2;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    min-height: 100px;
    padding: 0.65rem;
  }

  .logo-card img {
    display: block;
    height: 56px;
    max-width: min(100%, 180px);
    object-fit: contain;
    width: 100%;
  }

  .expert-box {
    align-items: center;
    background: #f8fbf6;
    border-radius: 8px;
    display: grid;
    gap: 0.95rem;
    grid-template-columns: minmax(180px, 260px) 1fr;
    padding: 0.95rem;
  }

  .expert-box img {
    border-radius: 8px;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .expert-box blockquote {
    color: #32463a;
    font-size: 1.03rem;
    line-height: 1.5;
    margin: 0;
  }

  .expert-box p {
    color: #5f871d;
    font-weight: 700;
    grid-column: 2 / 3;
    margin: 0;
  }

  .final-cta {
    align-items: center;
    background: #6f9c21;
    border-radius: 8px;
    display: grid;
    gap: 0.72rem;
    justify-items: center;
    padding: clamp(1.1rem, 2vw, 1.5rem) 1rem;
    text-align: center;
  }

  .final-cta h2 {
    color: #fff;
    font-size: clamp(1.45rem, 2.1vw, 2rem);
    margin: 0;
  }

